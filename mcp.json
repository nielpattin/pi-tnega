{
  "settings": {
    "toolPrefix": "short",
    "idleTimeout": 10,
    "directTools": false
  },
  "mcpServers": {
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "lifecycle": "keep-alive"
    },
    "atlassian-rovo": {
      "url": "https://mcp.atlassian.com/v1/mcp",
      "auth": "oauth"
    },
    "aspire": {
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ]
    },
    "browseros": {
      "url": "http://127.0.0.1:9000/mcp",
      "lifecycle": "lazy"
    },
    "pencil": {
      "command": "C:\\Users\\niel\\.pencil\\mcp\\visual_studio_code\\out\\mcp-server-windows-x64.exe",
      "args": [
        "--app",
        "visual_studio_code",
        "--agent",
        "openCodeCLI"
      ]
    },
    "documine": {
      "command": "npx",
      "args": [
        "tsx",
        "D:\\repo\\documine\\mcp-server\\src\\index.ts",
        "--data=D:\\repo\\documine\\data"
      ]
    }
  },
  "imports": [
    "cursor",
    "codex",
    "claude-code"
  ]
}