{
  "settings": {
    "toolPrefix": "short",
    "idleTimeout": 10,
    "directTools": false
  },
  "mcpServers": {
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "lifecycle": "keep-alive"
    },
    "atlassian-rovo": {
      "url": "https://mcp.atlassian.com/v1/mcp",
      "auth": "oauth"
    },
    "aspire": {
      "command": "aspire",
      "args": ["agent", "mcp"]
    }
  }
}
