{
  "settings": {
    "toolPrefix": "short",
    "idleTimeout": 10,
    "directTools": false
  },
  "mcpServers": {
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "lifecycle": "keep-alive"
    },
    "atlassian-rovo": {
      "url": "https://mcp.atlassian.com/v1/mcp",
      "auth": "oauth"
    },
    "aspire": {
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ]
    },
    "drawio": {
      "command": "npx",
      "args": [
        "@next-ai-drawio/mcp-server@latest"
      ],
      "enable": false
    },
    "browseros": {
      "url": "http://127.0.0.1:9000/mcp",
      "lifecycle": "lazy"
    }
  },
  "imports": [
    "cursor",
    "codex"
  ]
}
