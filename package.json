{
   "type": "module",
   "scripts": {
      "check": "pnpm run fmt:check && pnpm run lint && pnpm run test",
      "test": "vitest run",
      "test:watch": "vitest",
      "lint": "oxlint -c oxlint.config.ts --no-error-on-unmatched-pattern",
      "lint:fix": "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern",
      "fmt": "oxfmt -c oxfmt.config.ts",
      "fmt:check": "oxfmt -c oxfmt.config.ts --check",
      "prepare": "husky"
   },
   "dependencies": {
      "@earendil-works/pi-agent-core": "^0.75.5",
      "@earendil-works/pi-ai": "^0.75.5",
      "@earendil-works/pi-coding-agent": "^0.75.5",
      "@earendil-works/pi-tui": "^0.75.5",
      "@sinclair/typebox": "^0.34.49",
      "fzf": "^0.5.2",
      "typebox": "^1.1.38"
   },
   "devDependencies": {
      "@types/node": "^25.9.1",
      "husky": "^9.1.7",
      "lint-staged": "^17.0.5",
      "oxfmt": "^0.50.0",
      "oxlint": "^1.66.0",
      "oxlint-tsgolint": "^0.22.1",
      "typescript": "^6.0.3",
      "vitest": "^4.1.7",
      "yoctocolors": "2.1.2"
   },
   "lint-staged": {
      "*.{js,jsx,ts,tsx,mjs,cjs}": [
         "pnpm run lint:fix",
         "pnpm run fmt"
      ]
   },
   "packageManager": "pnpm@11.2.2"
}
