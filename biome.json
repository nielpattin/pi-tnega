{
   "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
   "vcs": {
      "enabled": true,
      "clientKind": "git",
      "useIgnoreFile": true
   },
   "files": {
      "ignoreUnknown": true,
      "includes": [
         "**",
         "!dist",
         "!build",
         "!node_modules",
         "!skills",
         "!packages",
         "!**/pi-mcp-adapter",
         "!**/test",
         "!**/tests",
         "!**/*.test.ts",
         "!preciseVerboseReporter.ts",
         "!*/recover-mimo-thinking.ts",
         "!*/treepluss",
         "!settings.json",
         "!mcp.json",
         "!pnpm-workspace.yaml",
         "!*.yml",
         "!.pi"
      ]
   },
   "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 3,
      "lineWidth": 120,
      "formatWithErrors": true
   },
   "assist": {
      "actions": {
         "source": {
            "organizeImports": "off"
         }
      }
   },
   "linter": {
      "enabled": true,
      "domains": {
         "project": "all"
      },
      "rules": {
         "recommended": true,
         "suspicious": {
            "noControlCharactersInRegex": "off",
            "useIterableCallbackReturn": "off",
            "noAssignInExpressions": "off",
            "noImplicitAnyLet": "off",
            "noExplicitAny": "off",
            "noDeprecatedImports": "off"
         },
         "style": {
            "noNonNullAssertion": "off",
            "useNodejsImportProtocol": "off"
         },
         "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off",
            "noUnusedFunctionParameters": "off",
            "noUnresolvedImports": "off",
            "useImportExtensions": "off",
            "noUndeclaredDependencies": "off"
         }
      }
   },
   "javascript": {
      "formatter": {
         "trailingCommas": "none",
         "semicolons": "always"
      }
   },
   "overrides": [
      {
         "includes": ["**/*.md", "**/*.html"],
         "formatter": {
            "indentWidth": 4
         }
      }
   ]
}
