      "build": "bun run typecheck",
      "test": "bun test"
   },
   "devDependencies": {
      "@earendil-works/pi-ai": "^0.74.0",
      "@earendil-works/pi-coding-agent": "^0.74.0",
      "@types/node": "^25.6.0",
      "typescript": "^6.0.3"
   },
   "peerDependencies": {
      "@earendil-works/pi-ai": "^0.74.0",
      "@earendil-works/pi-coding-agent": "^0.74.0"
   },
   "engines": {
      "node": ">=20"
